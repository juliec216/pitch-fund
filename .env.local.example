# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
# Model guarding the fund (any current Claude model id)
MODEL=claude-sonnet-4-6

# Spectrum (from https://app.photon.codes -> project Settings)
PROJECT_ID=
PROJECT_SECRET=

# Total fund in whole US dollars (default 100)
FUND_USD=100

# Where the SQLite file lives (shared by the agent worker and the dashboard)
DB_PATH=./fund.db

# Optional override for the Spectrum API host (default https://spectrum.photon.codes)
# SPECTRUM_BASE=
